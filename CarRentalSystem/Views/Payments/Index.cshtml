
@model IEnumerable<CarRentalSystem.Models.Payment>

@{
    ViewData["Title"] = "Payments";
}

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="fw-bold">
            Payments
        </h1>

        <a asp-action="Create"
           class="btn btn-success">
            Add Payment
        </a>

    </div>

    <div class="card border-0 shadow">

        <div class="card-header bg-dark text-white">

            <h4 class="mb-0">
                💳 Payment History
            </h4>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Car</th>
                        <th>Rental Period</th>
                        <th>Method</th>
                        <th>Amount</th>
                        <th>Payment Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var payment in Model)
                    {
                        <tr>

                            <td>
                                <strong>
                                    @payment.Reservation?.Car?.Brand
                                    @payment.Reservation?.Car?.Model
                                </strong>
                            </td>

                            <td>
                                @payment.Reservation?.StartDate.ToString("dd/MM/yyyy")
                                -
                                @payment.Reservation?.EndDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                <span class="badge bg-primary">
                                    @payment.PaymentMethod
                                </span>
                            </td>

                            <td class="fw-bold text-success">
                                €@payment.Amount
                            </td>

                            <td>
                                @payment.PaymentDate.ToString("dd/MM/yyyy HH:mm")
                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@payment.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@payment.Id"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

