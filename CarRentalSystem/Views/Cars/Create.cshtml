
@model CarRentalSystem.Models.Car

@{
    ViewData["Title"] = "Create Car";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-header bg-success text-white">

                    <h3 class="mb-0">
                        🚗 Add New Car
                    </h3>

                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="Brand"
                                       class="form-label">
                                </label>

                                <input asp-for="Brand"
                                       class="form-control" />

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="Model"
                                       class="form-label">
                                </label>

                                <input asp-for="Model"
                                       class="form-control" />

                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label asp-for="Year"
                                       class="form-label">
                                </label>

                                <input asp-for="Year"
                                       class="form-control" />

                            </div>

                            <div class="col-md-6 mb-3">

                                <label asp-for="PricePerDay"
                                       class="form-label">
                                </label>

                                <input asp-for="PricePerDay"
                                       class="form-control" />

                            </div>

                        </div>

                        <div class="mb-3">

                            <label asp-for="ImageUrl"
                                   class="form-label">
                            </label>

                            <input asp-for="ImageUrl"
                                   class="form-control" />

                        </div>

                        <div class="mb-3">

                            <label asp-for="CategoryId"
                                   class="form-label">
                            </label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="form-select">
                            </select>

                        </div>

                        <div class="form-check mb-4">

                            <input asp-for="IsAvailable"
                                   class="form-check-input" />

                            <label asp-for="IsAvailable"
                                   class="form-check-label">
                            </label>

                        </div>

                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-success">
                                Create Car
                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
