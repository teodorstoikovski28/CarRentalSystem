@model IEnumerable<CarRentalSystem.Models.Car>

@{
    ViewData["Title"] = "Cars";
}

<h2 class="fw-bold mb-4">
    Available Cars
</h2>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">

        <form method="get" asp-action="Index">

            <div class="row g-3 align-items-center">

                <div class="col-md-5">
                    <input type="text"
                           name="searchTerm"
                           class="form-control"
                           placeholder="Search by brand or model..."
                           value="@Context.Request.Query["searchTerm"]" />
                </div>

                <div class="col-md-3">
                    <select name="sortOrder" class="form-select">

                        <option value="">
                            Sort By
                        </option>

                        <option value="priceAsc"
                                selected="@(ViewBag.SortOrder == "priceAsc")">
                            Price: Low to High
                        </option>

                        <option value="priceDesc"
                                selected="@(ViewBag.SortOrder == "priceDesc")">
                            Price: High to Low
                        </option>

                        <option value="newest"
                                selected="@(ViewBag.SortOrder == "newest")">
                            Newest Added
                        </option>

                        <option value="oldest"
                                selected="@(ViewBag.SortOrder == "oldest")">
                            Oldest Added
                        </option>

                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit"
                            class="btn btn-primary w-100">
                        Search
                    </button>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="col-md-2">
                        <a asp-action="Create"
                           class="btn btn-success w-100">
                            Add Car
                        </a>
                    </div>
                }

            </div>

        </form>

    </div>
</div>

<div class="row g-4">

    @foreach (var car in Model)
    {
        var currentlyReserved =
            car.Reservations.Any(r =>
                DateTime.Today >= r.StartDate.Date &&
                DateTime.Today <= r.EndDate.Date);

        <div class="col-xl-3 col-lg-4 col-md-6">

            <div class="card h-100 border-0 shadow rounded-4 overflow-hidden">

                <div style="position:relative;">

                    <img src="@car.ImageUrl"
                         class="card-img-top"
                         style="height:220px;object-fit:cover;" />

                    @if (currentlyReserved)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">
                            Currently Reserved
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success position-absolute top-0 end-0 m-2">
                            Available Now
                        </span>
                    }

                </div>

                <div class="card-body d-flex flex-column">

                    <h5 class="fw-bold">
                        @car.Brand @car.Model
                    </h5>

                    <p class="text-muted mb-2">
                        @car.Category?.Name
                    </p>

                    <p class="mb-3">
                        Year: @car.Year
                    </p>

                    <div class="mt-auto">

                        <div class="fs-4 fw-bold text-success mb-3">
                            €@car.PricePerDay/day
                        </div>

                        <div class="d-grid gap-2">

                            <a asp-action="Details"
                               asp-route-id="@car.Id"
                               class="btn btn-outline-primary">
                                Details
                            </a>

                            @if (User.IsInRole("User"))
                            {
                                <a asp-controller="Reservations"
                                   asp-action="Create"
                                   asp-route-carId="@car.Id"
                                   class="btn btn-success">
                                    Rent Now
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit"
                                   asp-route-id="@car.Id"
                                   class="btn btn-warning">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@car.Id"
                                   class="btn btn-danger">
                                    Delete
                                </a>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>
    }

</div>
