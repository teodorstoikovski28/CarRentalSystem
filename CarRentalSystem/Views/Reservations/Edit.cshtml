@model CarRentalSystem.Models.Reservation

<div class="container">

    <div class="card shadow-lg border-0">

        <div class="card-body">

            <h2 class="text-center mb-4">
                Edit Reservation
            </h2>

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <form asp-action="Edit" method="post">

                <input asp-for="Id" type="hidden" />
                <input asp-for="UserId" type="hidden" />
                <input asp-for="TotalPrice" type="hidden" />
                <input asp-for="PaymentMethod" type="hidden" />

                <div class="mb-3">

                    <label asp-for="CarId"
                           class="form-label">
                    </label>

                    <select asp-for="CarId"
                            asp-items="ViewBag.Cars"
                            class="form-select">
                    </select>

                </div>

                <div class="mb-3">

                    <label asp-for="StartDate"
                           class="form-label">
                    </label>

                    <input asp-for="StartDate"
                           type="date"
                           class="form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />

                </div>

                <div class="mb-4">

                    <label asp-for="EndDate"
                           class="form-label">
                    </label>

                    <input asp-for="EndDate"
                           type="date"
                           class="form-control"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />

                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-success">
                        Save Changes
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        Back
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>