
@model CarRentalSystem.Models.Reservation

@{
    ViewData["Title"] = "Reservation Details";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        📅 Reservation Details
                    </h3>

                </div>

                <div class="card-body p-4">

                    <div class="row mb-4">

                        <div class="col-md-6">

                            <h6 class="text-muted">
                                Car
                            </h6>

                            <h4 class="fw-bold">
                                @Model.Car?.Brand @Model.Car?.Model
                            </h4>

                        </div>

                        <div class="col-md-6 text-md-end">

                            <h6 class="text-muted">
                                Reservation ID
                            </h6>

                            <h4>
                                #@Model.Id
                            </h4>

                        </div>

                    </div>

                    <hr />

                    <div class="row mb-4">

                        <div class="col-md-4">

                            <h6 class="text-muted">
                                Start Date
                            </h6>

                            <h5>
                                @Model.StartDate.ToString("dd/MM/yyyy")
                            </h5>

                        </div>

                        <div class="col-md-4">

                            <h6 class="text-muted">
                                End Date
                            </h6>

                            <h5>
                                @Model.EndDate.ToString("dd/MM/yyyy")
                            </h5>

                        </div>

                        <div class="col-md-4">

                            <h6 class="text-muted">
                                Total Price
                            </h6>

                            <h3 class="text-success fw-bold">
                                €@Model.TotalPrice
                            </h3>

                        </div>

                    </div>

                    <hr />

                    <div class="d-flex gap-2">

                        @if (Model.StartDate.Date > DateTime.Today)
                        {
                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-warning">
                                Edit Reservation
                            </a>
                        }

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Back
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

