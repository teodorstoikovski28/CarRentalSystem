@model CarRentalSystem.Models.Reservation

<div class="container">

    <div class="card shadow-lg border-0">

        <div class="card-body">

            <h2 class="mb-4 text-center">
                Create Reservation
            </h2>

            @if (ViewBag.CarImage != null)
            {
                <div class="text-center mb-4">

                    <img src="@ViewBag.CarImage"
                         class="img-fluid rounded shadow"
                         style="max-width:600px;
                    height:320px;
                    object-fit:cover;" />

                    <h2 class="mt-3">
                        @ViewBag.CarName
                    </h2>

                </div>
            }

            @if (ViewBag.ReservedPeriods != null)
            {
                <div class="alert alert-warning">

                    <h5>
                        Reserved periods
                    </h5>

                    <ul class="mb-0">
                        @foreach (var reservation in ViewBag.ReservedPeriods)
                        {
                            <li>
                                @reservation.StartDate.ToShortDateString()
                                -
                                @reservation.EndDate.ToShortDateString()
                            </li>
                        }
                    </ul>

                </div>
            }

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <form asp-action="Create" method="post">

                <input type="hidden" asp-for="CarId" />

                <div class="mb-3">

                    <label class="form-label">
                        Car
                    </label>

                    <input class="form-control"
                           value="@ViewBag.CarName"
                           readonly />

                </div>

                <div class="mb-3">

                    <label asp-for="StartDate"
                           class="form-label">
                    </label>

                    <input asp-for="StartDate"
                           type="date"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           id="startDate"
                           class="form-control" />

                </div>

                <div class="mb-3">

                    <label asp-for="EndDate"
                           class="form-label">
                    </label>

                    <input asp-for="EndDate"
                           type="date"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           id="endDate"
                           class="form-control" />

                </div>

                <div class="alert alert-info mb-4">

                    <h5>
                        Price Preview
                    </h5>

                    <p>
                        Days:
                        <span id="daysCount">0</span>
                    </p>

                    <p>
                        Price Per Day:
                        €<span id="pricePerDay">@ViewBag.PricePerDay</span>
                    </p>

                    <p class="fw-bold">
                        Total:
                        €<span id="totalPrice">0</span>
                    </p>

                </div>

                <div class="mb-4">

                    <label class="form-label">
                        Payment Method
                    </label>

                    <select asp-for="PaymentMethod"
                            class="form-select">

                        <option value="Cash">
                            Cash
                        </option>

                        <option value="Card">
                            Card
                        </option>

                        <option value="Bank Transfer">
                            Bank Transfer
                        </option>

                    </select>

                </div>

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-success btn-lg">
                        Confirm Reservation
                    </button>

                    <a asp-controller="Cars"
                       asp-action="Index"
                       class="btn btn-secondary btn-lg">
                        Back
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<script>

    const startDate =
        document.getElementById("startDate");

    const endDate =
        document.getElementById("endDate");

    const pricePerDay =
        parseFloat(document.getElementById("pricePerDay").innerText);

    function calculatePrice()
    {
        if (!startDate.value || !endDate.value)
        {
            return;
        }

        const start =
            new Date(startDate.value);

        const end =
            new Date(endDate.value);

        let days =
            Math.ceil((end - start) / (1000 * 60 * 60 * 24));

        if (days < 1)
        {
            days = 1;
        }

        document.getElementById("daysCount").innerText =
            days;

        document.getElementById("totalPrice").innerText =
            (days * pricePerDay).toFixed(2);
    }

    startDate.addEventListener("change", function () {

        endDate.min = this.value;

        if (endDate.value < this.value)
        {
            endDate.value = this.value;
        }

        calculatePrice();
    });

    endDate.addEventListener("change", calculatePrice);

</script>