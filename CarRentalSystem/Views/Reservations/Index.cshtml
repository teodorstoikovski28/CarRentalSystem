@model IEnumerable<CarRentalSystem.Models.Reservation>

@{
    ViewData["Title"] = "Reservations";

    var today = DateTime.Today;

    var currentReservations = Model
        .Where(r => today >= r.StartDate.Date &&
                    today <= r.EndDate.Date)
        .ToList();

    var upcomingReservations = Model
        .Where(r => r.StartDate.Date > today)
        .ToList();

    var pastReservations = Model
        .Where(r => r.EndDate.Date < today)
        .ToList();
}

<div class="container">

    <h1 class="fw-bold mb-4">
        Reservations
    </h1>

    @if (User.IsInRole("User"))
    {
        <div class="alert alert-info">
            Manage your current, upcoming and past reservations.
        </div>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="alert alert-warning">
            Administrator view - displaying all reservations.
        </div>
    }

    <!-- Current Reservations -->

    <div class="card border-0 shadow mb-5">

        <div class="card-header bg-success text-white">

            <h4 class="mb-0">
                🟢 Current Reservations
            </h4>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Car</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Price</th>
                        <th>Payment Method</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var reservation in currentReservations)
                    {
                        <tr>

                            <td>
                                <strong>
                                    @reservation.Car?.Brand
                                    @reservation.Car?.Model
                                </strong>
                            </td>

                            <td>
                                @reservation.StartDate.ToShortDateString()
                            </td>

                            <td>
                                @reservation.EndDate.ToShortDateString()
                            </td>

                            <td class="fw-bold text-success">
                                €@reservation.TotalPrice
                            </td>

                            <td>
                                @reservation.PaymentMethod
                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Upcoming Reservations -->

    <div class="card border-0 shadow mb-5">

        <div class="card-header bg-primary text-white">

            <h4 class="mb-0">
                📅 Upcoming Reservations
            </h4>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Car</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Price</th>
                        <th>Payment Method</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var reservation in upcomingReservations)
                    {
                        <tr>

                            <td>
                                <strong>
                                    @reservation.Car?.Brand
                                    @reservation.Car?.Model
                                </strong>
                            </td>

                            <td>
                                @reservation.StartDate.ToShortDateString()
                            </td>

                            <td>
                                @reservation.EndDate.ToShortDateString()
                            </td>

                            <td class="fw-bold text-success">
                                €@reservation.TotalPrice
                            </td>

                            <td>
                                @reservation.PaymentMethod
                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-danger btn-sm">
                                    Cancel
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Past Reservations -->

    <div class="card border-0 shadow">

        <div class="card-header bg-secondary text-white">

            <h4 class="mb-0">
                📚 Past Reservations
            </h4>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Car</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Price</th>
                        <th>Payment Method</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var reservation in pastReservations)
                    {
                        <tr>

                            <td>
                                <strong>
                                    @reservation.Car?.Brand
                                    @reservation.Car?.Model
                                </strong>
                            </td>

                            <td>
                                @reservation.StartDate.ToShortDateString()
                            </td>

                            <td>
                                @reservation.EndDate.ToShortDateString()
                            </td>

                            <td class="fw-bold text-success">
                                €@reservation.TotalPrice
                            </td>

                            <td>
                                @reservation.PaymentMethod
                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@reservation.Id"
                                   class="btn btn-info btn-sm">
                                    Details
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
