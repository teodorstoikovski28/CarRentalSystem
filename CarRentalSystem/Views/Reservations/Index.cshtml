@model IEnumerable<CarRentalSystem.Models.Reservation>

<h2>My Reservations</h2>

@if (User.IsInRole("User"))
{
    <p>
        Here are your reservations.
    </p>
}

@if (User.IsInRole("Admin"))
{
    <p>
        Admin view - all reservations.
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Car</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Total Price</th>
            <th>Payment Method</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var reservation in Model)
        {
            <tr>
                <td>@reservation.Car?.Brand @reservation.Car?.Model</td>
                <td>@reservation.StartDate.ToShortDateString()</td>
                <td>@reservation.EndDate.ToShortDateString()</td>
                <td>@reservation.TotalPrice €</td>
                <td>@reservation.PaymentMethod</td>

                <td>
                    <a asp-action="Details"
                       asp-route-id="@reservation.Id"
                       class="btn btn-info">
                        Details
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@reservation.Id"
                       class="btn btn-danger">
                        Cancel Reservation
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>